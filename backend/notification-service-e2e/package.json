{
  "name": "@org/notification-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "notification-e2e",
    "implicitDependencies": [
      "notification"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "backend/notification-service-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "notification:build",
          "notification:serve"
        ]
      }
    }
  }
}
