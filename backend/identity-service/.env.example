PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@identity-db:5432/identity

JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RABBITMQ_URL=amqp://rabbitmq:rabbitmq@rabbitmq:5672

ALLOWED_REDIRECT_URIS=http://localhost:3000,http://localhost:3001

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=identity-avatars